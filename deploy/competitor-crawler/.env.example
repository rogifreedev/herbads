# Copy this file to .env on the server, or upload the prepared local .env.
HERBADS_REPO_URL=https://github.com/rogifreedev/herbads.git
HERBADS_REF=main

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

COMPETITOR_CRAWL_WORKER_ID=competitor-crawler-01
COMPETITOR_CRAWL_POLL_INTERVAL_MS=5000
COMPETITOR_CRAWL_WORKER_BATCH_SIZE=1
COMPETITOR_CRAWL_HEARTBEAT_INTERVAL_MS=15000
COMPETITOR_CRAWL_JOB_MAX_ATTEMPTS=3
COMPETITOR_CRAWL_JOB_RETRY_BASE_SECONDS=120
COMPETITOR_CRAWL_JOB_STALE_RUNNING_MINUTES=45
COMPETITOR_CRAWLER_HEALTH_HOST=0.0.0.0
COMPETITOR_CRAWLER_HEALTH_PORT=39123

COMPETITOR_BROWSER_CRAWL=1
COMPETITOR_CRAWL_CONCURRENCY=4
COMPETITOR_REFRESH_EXISTING_MEDIA=1
COMPETITOR_DEFAULT_CPM=12
COMPETITOR_CRAWL_RUN_ONCE=0

LOG_LEVEL=info
